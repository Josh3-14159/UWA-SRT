#!/bin/bash
# srt-watchdog — periodic health check fired by srt-watchdog.timer every 30s.

SRT=/mnt/srt
GO="$SRT/go"
DRIVE="$SRT/drive"
SETUP="$SRT/srt-setup"
SENTINEL=/run/srt/ready

log() { echo "[srt-watchdog] $*"; }

NEEDS_SETUP=0
NEEDS_RESTART=0

systemctl is-active --quiet srt-go.service || { log "WARN: srt-go not active."; NEEDS_RESTART=1; }

for f in cw ccw up dn; do
    [ -f "$GO/$f" ] || { log "WARN: $GO/$f missing."; NEEDS_SETUP=1; break; }
done

if [ -d "$GO" ] && ! touch "$GO/.watchdog_probe" 2>/dev/null; then
    log "WARN: $GO not writable."; NEEDS_SETUP=1
else
    rm -f "$GO/.watchdog_probe"
fi

for f in cw ccw up dn; do
    { [ -L "$DRIVE/$f" ] && [ -e "$DRIVE/$f" ]; } || { log "WARN: $DRIVE/$f broken."; NEEDS_SETUP=1; break; }
done

if [ "$NEEDS_SETUP" -eq 1 ]; then
    log "Running srt-setup to recover."
    if bash "$SETUP"; then
        log "srt-setup completed."
        touch "$SENTINEL"
        NEEDS_RESTART=1
    else
        log "ERROR: srt-setup failed — manual intervention required."
        exit 1
    fi
fi

if [ "$NEEDS_RESTART" -eq 1 ]; then
    log "Restarting srt-go.service."
    systemctl restart srt-go.service
fi

[ "$NEEDS_SETUP" -eq 0 ] && [ "$NEEDS_RESTART" -eq 0 ] && log "All checks passed."
