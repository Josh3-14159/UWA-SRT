#!/bin/bash
# hal/srt-init — runs srt-setup on start, touches /run/srt/ready once the
#                first setup succeeds, then watches rp2040fs@srt journal for
#                "Device alive." and re-runs srt-setup on every reconnect.
#
# /run/srt/ready is the sentinel that control-layer daemons poll before
# starting. It is cleared on exit so they always wait for a fresh successful
# setup after a restart.

SRT=/mnt/srt
SETUP="$SRT/hal/srt-setup"
FUSE_SERVICE="rp2040fs@srt.service"
SENTINEL=/run/srt/ready

set -uo pipefail

log() { echo "[srt-init] $*"; }

mkdir -p /run/srt
rm -f "$SENTINEL"

cleanup() {
    log "Exiting — clearing sentinel."
    rm -f "$SENTINEL"
}
trap cleanup EXIT

log "Starting — running srt-setup for initial state."
if bash "$SETUP"; then
    log "Initial srt-setup completed successfully."
    touch "$SENTINEL"
    log "Sentinel written to $SENTINEL."
else
    log "WARNING: Initial srt-setup failed — board may not be connected yet."
    log "         Will retry on next 'Device alive.' event."
fi

log "Watching $FUSE_SERVICE for 'Device alive.' events..."

journalctl -fu "$FUSE_SERVICE" -o cat | while read -r line; do
    if [[ "$line" == *"Device alive."* ]]; then
        log "Device alive. detected — running srt-setup"
        if bash "$SETUP"; then
            log "srt-setup completed successfully."
            touch "$SENTINEL"
        else
            log "ERROR: srt-setup failed (exit $?) — check the log above."
            rm -f "$SENTINEL"
        fi
    fi
done

