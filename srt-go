#!/bin/bash
# srt-go — watches go/ for writes, enforces per-axis mutual exclusion,
#           and proxies the result to drive/ symlinks.
#
# Waits for /run/srt/ready (written by srt-init after a successful srt-setup)
# before starting the inotify loop. This prevents a race with srt-setup on
# startup or after a reconnect.
#
# Sends WATCHDOG=1 keepalives to systemd every $WATCHDOG_PING seconds.
#
# Az axis:  cw  and ccw  are exclusive — writing 1 to one zeros the other
# El axis:  up  and dn   are exclusive — writing 1 to one zeros the other
# Az and El are fully independent — both axes may slew simultaneously.
#
# Usage:
#   echo 1 > /mnt/srt/go/cw       start slewing CW
#   echo 0 > /mnt/srt/go/cw       stop CW
#   echo 0 > /mnt/srt/go/*        stop all

SRT=/mnt/srt
GO="$SRT/go"
DRIVE="$SRT/drive"
SENTINEL=/run/srt/ready
WATCHDOG_PING=10        # seconds between sd_notify keepalives
SENTINEL_TIMEOUT=60     # seconds to wait for sentinel before giving up

set -euo pipefail

log() { echo "[srt-go] $*"; }

# ── wait for sentinel ─────────────────────────────────────────────────────────

log "Waiting for $SENTINEL (srt-init must complete srt-setup first)..."
elapsed=0
while [ ! -f "$SENTINEL" ]; do
    if [ "$elapsed" -ge "$SENTINEL_TIMEOUT" ]; then
        log "ERROR: timed out after ${SENTINEL_TIMEOUT}s waiting for $SENTINEL." >&2
        log "       Check srt-init: journalctl -u srt-init" >&2
        exit 1
    fi
    sleep 1
    (( elapsed++ )) || true
done
log "Sentinel found after ${elapsed}s — proceeding."

# ── preflight checks ──────────────────────────────────────────────────────────

for f in cw ccw up dn; do
    if [ ! -f "$GO/$f" ]; then
        log "ERROR: $GO/$f not found — srt-setup may have failed." >&2
        exit 1
    fi
    if [ ! -L "$DRIVE/$f" ]; then
        log "ERROR: $DRIVE/$f symlink not found — srt-setup may have failed." >&2
        exit 1
    fi
done

command -v inotifywait >/dev/null 2>&1 || {
    log "ERROR: inotifywait not found — install inotify-tools." >&2
    exit 1
}

# ── systemd watchdog keepalive ────────────────────────────────────────────────

watchdog_ping() {
    while true; do
        systemd-notify WATCHDOG=1 2>/dev/null || true
        sleep "$WATCHDOG_PING"
    done
}
watchdog_ping &
WATCHDOG_PID=$!

cleanup() {
    log "Shutting down — zeroing all drive pins."
    for f in cw ccw up dn; do
        echo "0" > "$DRIVE/$f" 2>/dev/null || true
        echo "0" > "$GO/$f"    2>/dev/null || true
    done
    kill "$WATCHDOG_PID" 2>/dev/null || true
}
trap cleanup EXIT

systemd-notify --ready 2>/dev/null || true

# ── mutual exclusion helper ───────────────────────────────────────────────────

apply_axis() {
    local req="$1" opp="$2"
    local val
    val=$(tr -d '[:space:]' < "$GO/$req")

    if [[ "$val" != "0" && "$val" != "1" ]]; then
        log "WARN: ignored invalid value '$val' written to go/$req"
        cat "$DRIVE/$req" > "$GO/$req"
        return
    fi

    if [[ "$val" == "1" ]]; then
        echo "0" > "$DRIVE/$opp"
        echo "0" > "$GO/$opp"
        log "$req=1 → zeroed $opp"
    fi

    echo "$val" > "$DRIVE/$req"
    log "$req=$val"
}

# ── main inotify loop ─────────────────────────────────────────────────────────

log "Started. Watching $GO for changes."

inotifywait -m -q -e close_write --format '%f' "$GO" | while read -r filename; do
    case "$filename" in
        cw|ccw) apply_axis "$filename" "$([ "$filename" = cw ] && echo ccw || echo cw)" ;;
        up|dn)  apply_axis "$filename" "$([ "$filename" = up ] && echo dn  || echo up)"  ;;
        *)      log "WARN: ignored write to unknown file go/$filename" ;;
    esac
done
